{
  "name": "picocalc",
  "version": "0.0.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/picocalc/picocalc.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#src": "./src/index.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench": "bun --cpu-prof-md --cpu-prof-dir ./bench/profiles bench/index.ts",
    "test": "bun test --dots",
    "lint": "oxlint",
    "format": "oxfmt",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "bigint.bitlength": "0.2.0"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.5",
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.22.7",
    "typescript": "6.0.3"
  }
}
